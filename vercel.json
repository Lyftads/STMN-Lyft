{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/competitor-intel?refresh=1",
      "schedule": "0 6 */2 * *"
    },
    {
      "path": "/api/cron/auto-scan",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/sync-costs",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/customer-snapshots",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/consolidate-memories",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/scheduled-reports",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/scheduled-reports",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/task-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/team-standup",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/team-tasks",
      "schedule": "0 7 * * 1"
    }
  ]
}
